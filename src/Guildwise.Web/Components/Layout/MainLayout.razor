@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="app-sidebar" aria-label="Guildwise navigation">
        <a class="app-brand" href="/roster">
            <span class="app-brand__mark">GW</span>
            <span>
                <strong>Guildwise</strong>
                <small>Roster command</small>
            </span>
        </a>

        <nav class="app-nav">
            <NavLink href="/roster" Match="NavLinkMatch.All">Roster overview</NavLink>
            <NavLink href="/roster-setup">Roster setup</NavLink>
        </nav>
    </aside>

    <div class="app-content">
        @Body
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
