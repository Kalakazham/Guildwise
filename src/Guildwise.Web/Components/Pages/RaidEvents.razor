@page "/raid-events"
@rendermode InteractiveServer

@using Guildwise.Application.Contracts.Guilds
@using Guildwise.Application.Contracts.RaidEvents
@using Guildwise.Application.Contracts.RaidTeams
@using Guildwise.Application.Guilds.ListGuilds
@using Guildwise.Application.RaidEvents.ListRaidEvents
@inject ListGuildsHandler ListGuildsHandler
@inject ListRaidEventsHandler ListRaidEventsHandler

<PageTitle>Raid Events</PageTitle>

<main class="raid-events-page">
    <PageHeader
        Eyebrow="Guildwise raid planning"
        Title="Raid Events"
        Subtitle="Review planned raid dates, raid team ownership and guild context from the manual event foundation in Guildwise.">
        <Actions>
            <a class="event-action event-action--secondary" href="/raid-teams">Raid Teams</a>
            <button type="button" class="event-action" @onclick="LoadRaidEventsAsync">Refresh</button>
        </Actions>
    </PageHeader>

    @if (isLoading)
    {
        <LoadingState Title="Loading raid events" Message="Collecting event, guild and raid team context." />
    }
    else if (!string.IsNullOrWhiteSpace(loadFailure))
    {
        <ContentPanel Title="Raid events unavailable">
            <EmptyState
                Title="Raid event data could not be loaded."
                Message="@loadFailure">
                <Actions>
                    <button type="button" class="event-action" @onclick="LoadRaidEventsAsync">Try again</button>
                </Actions>
            </EmptyState>
        </ContentPanel>
    }
    else if (guilds.Count == 0)
    {
        <ContentPanel Title="Guild Context">
            <EmptyState
                Title="No guilds yet."
                Message="Create a guild and raid team through setup before planning raid events.">
                <Actions>
                    <a class="event-action" href="/roster-setup">Open roster setup</a>
                </Actions>
            </EmptyState>
        </ContentPanel>
    }
    else if (!HasAnyRaidTeams)
    {
        <ContentPanel Title="Raid Team Context">
            <EmptyState
                Title="No raid teams yet."
                Message="Raid events are assigned to raid teams. Create a raid team before reviewing planned events.">
                <Actions>
                    <a class="event-action" href="/raid-teams">Open raid teams</a>
                    <a class="event-action event-action--secondary" href="/roster-setup">Open roster setup</a>
                </Actions>
            </EmptyState>
        </ContentPanel>
    }
    else if (raidEvents.Count == 0)
    {
        <section class="event-summary-grid" aria-label="Raid event summary">
            <SummaryCard Label="Events" Value="0" Detail="No planned raid events" />
            <SummaryCard Label="Guilds" Value="@guilds.Count.ToString()" Detail="Available guild contexts" />
            <SummaryCard Label="Raid teams with events" Value="0" Detail="No event assignments yet" />
            <SummaryCard Label="Next event" Value="-" Detail="Create events in the next slice" />
        </section>

        <ContentPanel Title="Raid Event Overview">
            <EmptyState
                Title="No raid events yet."
                Message="Raid event persistence is available, but no raid events have been created yet." />
        </ContentPanel>
    }
    else
    {
        var selectedEvent = SelectedEvent;
        var orderedEvents = OrderedRaidEvents;

        <section class="event-summary-grid" aria-label="Raid event summary">
            <SummaryCard Label="Events" Value="@raidEvents.Count.ToString()" Detail="Planned raid dates" />
            <SummaryCard Label="Guilds" Value="@guilds.Count.ToString()" Detail="Available guild contexts" />
            <SummaryCard Label="Raid teams with events" Value="@RaidTeamsWithEventsCount.ToString()" Detail="Teams assigned to events" />
            <SummaryCard Label="Next event" Value="@FormatSummaryDate(orderedEvents.FirstOrDefault()?.StartTime)" Detail="@GetNextEventDetail(orderedEvents.FirstOrDefault())" />
        </section>

        <section class="event-management-grid">
            <ContentPanel Title="Event Overview" Class="event-overview-panel">
                <div class="event-list" role="list" aria-label="Raid events">
                    @foreach (var raidEvent in orderedEvents)
                    {
                        var isSelected = selectedEvent?.Id == raidEvent.Id;
                        var guild = FindGuild(raidEvent);
                        var raidTeam = FindRaidTeam(raidEvent);

                        <button
                            type="button"
                            class="event-list-item @(isSelected ? "event-list-item--selected" : string.Empty)"
                            @onclick="() => SelectEvent(raidEvent.Id)"
                            aria-pressed="@isSelected">
                            <span class="event-list-item__title">@raidEvent.Title</span>
                            <span class="event-list-item__time">@FormatDateTime(raidEvent.StartTime)</span>
                            <span class="event-list-item__context">
                                <RaidTeamBadge Name="@GetRaidTeamName(raidTeam)" />
                                <span>@GetGuildContext(guild)</span>
                            </span>
                            <span class="event-difficulty">@RosterDisplayText.RaidDifficulty(raidEvent.Difficulty)</span>
                        </button>
                    }
                </div>
            </ContentPanel>

            <ContentPanel Title="Event Detail" Class="event-detail-panel">
                @if (selectedEvent is null)
                {
                    <EmptyState
                        Title="No raid event selected."
                        Message="Choose a raid event from the overview to inspect its details." />
                }
                else
                {
                    var guild = FindGuild(selectedEvent);
                    var raidTeam = FindRaidTeam(selectedEvent);

                    <div class="event-detail-header">
                        <div>
                            <RaidTeamBadge Name="@GetRaidTeamName(raidTeam)" />
                            <h2>@selectedEvent.Title</h2>
                            <p>@GetGuildContext(guild)</p>
                        </div>
                        <span class="event-difficulty event-difficulty--large">@RosterDisplayText.RaidDifficulty(selectedEvent.Difficulty)</span>
                    </div>

                    <div class="event-detail-grid">
                        <section class="event-detail-card">
                            <span>Raid team</span>
                            <strong>@GetRaidTeamName(raidTeam)</strong>
                        </section>
                        <section class="event-detail-card">
                            <span>Guild</span>
                            <strong>@GetGuildName(guild)</strong>
                            <small>@GetGuildRealm(guild)</small>
                        </section>
                        <section class="event-detail-card">
                            <span>Start</span>
                            <strong>@FormatDateTime(selectedEvent.StartTime)</strong>
                        </section>
                        <section class="event-detail-card">
                            <span>End</span>
                            <strong>@FormatOptionalDateTime(selectedEvent.EndTime)</strong>
                        </section>
                        <section class="event-detail-card">
                            <span>Duration</span>
                            <strong>@FormatDuration(selectedEvent)</strong>
                        </section>
                        <section class="event-detail-card">
                            <span>Instance</span>
                            <strong>@selectedEvent.InstanceName</strong>
                        </section>
                    </div>

                    <section class="event-notes-panel" aria-label="Raid event notes">
                        <h3>Notes</h3>
                        @if (string.IsNullOrWhiteSpace(selectedEvent.Notes))
                        {
                            <p class="muted">No notes for this raid event.</p>
                        }
                        else
                        {
                            <p>@selectedEvent.Notes</p>
                        }
                    </section>
                }
            </ContentPanel>
        </section>
    }
</main>

@code {
    private IReadOnlyList<RaidEventDto> raidEvents = [];
    private IReadOnlyList<GuildDto> guilds = [];
    private bool isLoading = true;
    private string? loadFailure;
    private Guid? selectedRaidEventId;

    private IReadOnlyList<RaidEventDto> OrderedRaidEvents
        => raidEvents
            .OrderBy(raidEvent => raidEvent.StartTime)
            .ThenBy(raidEvent => raidEvent.Title, StringComparer.OrdinalIgnoreCase)
            .ThenBy(raidEvent => raidEvent.Id)
            .ToList();

    private RaidEventDto? SelectedEvent
        => raidEvents.FirstOrDefault(raidEvent => raidEvent.Id == selectedRaidEventId);

    private bool HasAnyRaidTeams
        => guilds.Any(guild => guild.RaidTeams.Count > 0);

    private int RaidTeamsWithEventsCount
        => raidEvents
            .Select(raidEvent => raidEvent.RaidTeamId)
            .Distinct()
            .Count();

    protected override async Task OnInitializedAsync()
    {
        await LoadRaidEventsAsync();
    }

    private async Task LoadRaidEventsAsync()
    {
        isLoading = true;
        loadFailure = null;

        try
        {
            guilds = await ListGuildsHandler.HandleAsync(new ListGuildsQuery());
            raidEvents = await ListRaidEventsHandler.HandleAsync(new ListRaidEventsQuery());
            EnsureSelection();
        }
        catch
        {
            guilds = [];
            raidEvents = [];
            selectedRaidEventId = null;
            loadFailure = "An unexpected technical failure occurred while loading raid events.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectEvent(Guid raidEventId)
    {
        selectedRaidEventId = raidEventId;
    }

    private void EnsureSelection()
    {
        if (raidEvents.Count == 0)
        {
            selectedRaidEventId = null;
            return;
        }

        if (selectedRaidEventId is null || raidEvents.All(raidEvent => raidEvent.Id != selectedRaidEventId.Value))
        {
            selectedRaidEventId = OrderedRaidEvents.First().Id;
        }
    }

    private GuildDto? FindGuild(RaidEventDto raidEvent)
        => guilds.FirstOrDefault(guild => guild.Id == raidEvent.GuildId);

    private RaidTeamDto? FindRaidTeam(RaidEventDto raidEvent)
        => FindGuild(raidEvent)?.RaidTeams.FirstOrDefault(raidTeam => raidTeam.Id == raidEvent.RaidTeamId);

    private static string GetGuildName(GuildDto? guild)
        => guild?.Name ?? "Unknown guild context";

    private static string GetGuildRealm(GuildDto? guild)
        => guild is null ? "Unknown realm" : $"{guild.Region} - {guild.Realm}";

    private static string GetGuildContext(GuildDto? guild)
        => guild is null ? "Unknown guild context" : $"{guild.Name} - {guild.Region} - {guild.Realm}";

    private static string GetRaidTeamName(RaidTeamDto? raidTeam)
        => raidTeam?.Name ?? "Unknown raid team";

    private static string FormatDateTime(DateTimeOffset value)
        => value.ToLocalTime().ToString("ddd, dd MMM yyyy HH:mm");

    private static string FormatOptionalDateTime(DateTimeOffset? value)
        => value.HasValue ? FormatDateTime(value.Value) : "Not set";

    private static string FormatSummaryDate(DateTimeOffset? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("dd MMM") : "-";

    private static string GetNextEventDetail(RaidEventDto? raidEvent)
        => raidEvent is null ? "No planned event" : raidEvent.Title;

    private static string FormatDuration(RaidEventDto raidEvent)
    {
        if (!raidEvent.EndTime.HasValue)
        {
            return "Not set";
        }

        var duration = raidEvent.EndTime.Value - raidEvent.StartTime;
        if (duration.TotalMinutes < 1)
        {
            return "Not set";
        }

        return duration.TotalHours >= 1
            ? $"{(int)duration.TotalHours}h {duration.Minutes}m"
            : $"{duration.Minutes}m";
    }
}
