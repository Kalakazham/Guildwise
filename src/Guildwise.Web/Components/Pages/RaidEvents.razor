    private int? GetMissingResponseCount(RaidEventDto raidEvent)
    {
        var guild = FindGuild(raidEvent);
        if (guild is null)
        {
            return null;
        }

        var signupPlayerIds = selectedEventSignups
            .Select(signup => signup.PlayerId)
            .ToHashSet();

        return guild.Members.Count(member => !signupPlayerIds.Contains(member.PlayerId));
    }

