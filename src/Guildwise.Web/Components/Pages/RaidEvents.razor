    {
        isEditingSelectedEvent = false;
        editInProgress = false;
        isConfirmingCancel = false;
        editTitle = string.Empty;
        editRaidTeamId = string.Empty;
        editStartDateTime = string.Empty;
        editEndDateTime = string.Empty;
        editInstanceName = string.Empty;
        editDifficulty = RaidDifficulty.Normal;
        editNotes = string.Empty;

        if (clearMessage)
        {
            editMessage = null;
        }
    }

