    private void ResetCreateForm(bool clearMessage)
    {
        createTitle = string.Empty;
        createStartDateTime = string.Empty;
        createEndDateTime = string.Empty;
        createInstanceName = string.Empty;
        createDifficulty = RaidDifficulty.Normal;
        createNotes = string.Empty;
        EnsureCreateRaidTeamSelection();

        if (clearMessage)
        {
            createMessage = null;
        }
    }

