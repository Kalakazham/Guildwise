@page "/raid-events"
@rendermode InteractiveServer

@using System.Globalization
@using Guildwise.Application.Common.Results
@using Guildwise.Application.Contracts.Guilds
@using Guildwise.Application.Contracts.RaidEvents
@using Guildwise.Application.Contracts.RaidTeams
@using Guildwise.Application.Guilds.ListGuilds
@using Guildwise.Application.RaidEvents.CancelRaidEvent
@using Guildwise.Application.RaidEvents.CreateRaidEvent
@using Guildwise.Application.RaidEvents.ListRaidEventSignups
@using Guildwise.Application.RaidEvents.ListRaidEvents
@using Guildwise.Application.RaidEvents.UpdateRaidEvent
@using Guildwise.Domain
@inject CancelRaidEventHandler CancelRaidEventHandler
@inject CreateRaidEventHandler CreateRaidEventHandler
@inject ListRaidEventSignupsHandler ListRaidEventSignupsHandler
@inject ListGuildsHandler ListGuildsHandler
@inject ListRaidEventsHandler ListRaidEventsHandler
@inject UpdateRaidEventHandler UpdateRaidEventHandler

<PageTitle>Raid Events</PageTitle>

<main class="raid-events-page">
    <PageHeader
        Eyebrow="Guildwise raid planning"
        Title="Raid Events"
        Subtitle="Review planned raid dates, raid team ownership and guild context from the manual event foundation in Guildwise.">
        <Actions>
            <a class="event-action event-action--secondary" href="/raid-teams">Raid Teams</a>
            <button type="button" class="event-action" @onclick="() => LoadRaidEventsAsync()">Refresh</button>
        </Actions>
    </PageHeader>

    @if (isLoading)
    {
        <LoadingState Title="Loading raid events" Message="Collecting event, guild and raid team context." />
    }
    else if (!string.IsNullOrWhiteSpace(loadFailure))
    {
        <ContentPanel Title="Raid events unavailable">
            <EmptyState
                Title="Raid event data could not be loaded."
                Message="@loadFailure">
                <Actions>
                    <button type="button" class="event-action" @onclick="() => LoadRaidEventsAsync()">Try again</button>
                </Actions>
            </EmptyState>
        </ContentPanel>
    }
    else if (guilds.Count == 0)
    {
        <ContentPanel Title="Guild Context">
            <EmptyState
                Title="No guilds yet."
                Message="Create a guild and raid team through setup before planning raid events.">
                <Actions>
                    <a class="event-action" href="/roster-setup">Open roster setup</a>
                </Actions>
            </EmptyState>
        </ContentPanel>
    }
    else if (!HasAnyRaidTeams)
    {
        <ContentPanel Title="Raid Team Context">
            <EmptyState
                Title="No raid teams yet."
                Message="Raid events are assigned to raid teams. Create a raid team before reviewing planned events.">
                <Actions>
                    <a class="event-action" href="/raid-teams">Open raid teams</a>
                    <a class="event-action event-action--secondary" href="/roster-setup">Open roster setup</a>
                </Actions>
            </EmptyState>
        </ContentPanel>
    }
    else if (raidEvents.Count == 0)
    {
        <section class="event-summary-grid" aria-label="Raid event summary">
            <SummaryCard Label="Events" Value="0" Detail="No planned raid events" />
            <SummaryCard Label="Guilds" Value="@guilds.Count.ToString()" Detail="Available guild contexts" />
            <SummaryCard Label="Raid teams with events" Value="0" Detail="No event assignments yet" />
            <SummaryCard Label="Next event" Value="-" Detail="No planned event" />
        </section>

        <section class="event-management-grid">
            <div class="event-management-sidebar">
                <ContentPanel Title="Create Raid Event" Class="event-create-panel">
                    <form class="event-create-form" @onsubmit="CreateRaidEventAsync" @onsubmit:preventDefault>
                        <div class="event-create-form__grid">
                            <label class="event-form-field event-form-field--wide">
                                Title
                                <input
                                    @bind="createTitle"
                                    disabled="@createInProgress"
                                    placeholder="Weekly progression raid" />
                            </label>

                            <label class="event-form-field event-form-field--wide">
                                Raid team
                                <select @bind="createRaidTeamId" disabled="@createInProgress">
                                    @foreach (var option in RaidTeamOptions)
                                    {
                                        <option value="@option.RaidTeamId.ToString()">@FormatRaidTeamOption(option)</option>
                                    }
                                </select>
                            </label>

                            <label class="event-form-field">
                                Start date/time
                                <input
                                    type="datetime-local"
                                    value="@createStartDateTime"
                                    @oninput="OnCreateStartDateTimeChanged"
                                    disabled="@createInProgress" />
                            </label>

                            <label class="event-form-field">
                                End date/time
                                <input
                                    type="datetime-local"
                                    value="@createEndDateTime"
                                    @oninput="OnCreateEndDateTimeChanged"
                                    disabled="@createInProgress" />
                            </label>

                            <label class="event-form-field">
                                Instance
                                <input
                                    @bind="createInstanceName"
                                    disabled="@createInProgress"
                                    placeholder="Manaforge Omega" />
                            </label>

                            <label class="event-form-field">
                                Difficulty
                                <select @bind="createDifficulty" disabled="@createInProgress">
                                    @foreach (var difficulty in RaidDifficultyOptions)
                                    {
                                        <option value="@difficulty">@RosterDisplayText.RaidDifficulty(difficulty)</option>
                                    }
                                </select>
                            </label>

                            <label class="event-form-field event-form-field--wide">
                                Notes
                                <textarea
                                    @bind="createNotes"
                                    disabled="@createInProgress"
                                    rows="3"
                                    placeholder="Optional planning notes"></textarea>
                            </label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(createMessage))
                        {
                            <div class="event-status-message event-status-message--@createStatus" role="status">
                                @createMessage
                            </div>
                        }

                        <div class="event-create-form__actions">
                            <button type="submit" class="event-action" disabled="@createInProgress">
                                @(createInProgress ? "Creating..." : "Create Event")
                            </button>
                            <button type="button" class="event-action event-action--secondary" disabled="@createInProgress" @onclick="CancelCreateForm">
                                Reset
                            </button>
                        </div>
                    </form>
                </ContentPanel>

                <ContentPanel Title="Raid Event Overview">
                    <EmptyState
                        Title="No raid events yet."
                        Message="Create the first raid event to start planning raid dates for an existing raid team." />
                </ContentPanel>
            </div>

            <ContentPanel Title="Event Detail" Class="event-detail-panel">
                <EmptyState
                    Title="No raid event selected."
                    Message="Create a raid event or choose one from the overview to inspect its details." />
            </ContentPanel>
        </section>
    }
    else
    {
        var selectedEvent = SelectedEvent;
        var orderedEvents = OrderedRaidEvents;

        <section class="event-summary-grid" aria-label="Raid event summary">
            <SummaryCard Label="Events" Value="@raidEvents.Count.ToString()" Detail="Planned raid dates" />
            <SummaryCard Label="Guilds" Value="@guilds.Count.ToString()" Detail="Available guild contexts" />
            <SummaryCard Label="Raid teams with events" Value="@RaidTeamsWithEventsCount.ToString()" Detail="Teams assigned to events" />
            <SummaryCard Label="Next event" Value="@FormatSummaryDate(orderedEvents.FirstOrDefault()?.StartTime)" Detail="@GetNextEventDetail(orderedEvents.FirstOrDefault())" />
        </section>

        <section class="event-management-grid">
            <div class="event-management-sidebar">
                <ContentPanel Title="Create Raid Event" Class="event-create-panel">
                    <form class="event-create-form" @onsubmit="CreateRaidEventAsync" @onsubmit:preventDefault>
                        <div class="event-create-form__grid">
                            <label class="event-form-field event-form-field--wide">
                                Title
                                <input
                                    @bind="createTitle"
                                    disabled="@createInProgress"
                                    placeholder="Weekly progression raid" />
                            </label>

                            <label class="event-form-field event-form-field--wide">
                                Raid team
                                <select @bind="createRaidTeamId" disabled="@createInProgress">
                                    @foreach (var option in RaidTeamOptions)
                                    {
                                        <option value="@option.RaidTeamId.ToString()">@FormatRaidTeamOption(option)</option>
                                    }
                                </select>
                            </label>

                            <label class="event-form-field">
                                Start date/time
                                <input
                                    type="datetime-local"
                                    value="@createStartDateTime"
                                    @oninput="OnCreateStartDateTimeChanged"
                                    disabled="@createInProgress" />
                            </label>

                            <label class="event-form-field">
                                End date/time
                                <input
                                    type="datetime-local"
                                    value="@createEndDateTime"
                                    @oninput="OnCreateEndDateTimeChanged"
                                    disabled="@createInProgress" />
                            </label>

                            <label class="event-form-field">
                                Instance
                                <input
                                    @bind="createInstanceName"
                                    disabled="@createInProgress"
                                    placeholder="Manaforge Omega" />
                            </label>

                            <label class="event-form-field">
                                Difficulty
                                <select @bind="createDifficulty" disabled="@createInProgress">
                                    @foreach (var difficulty in RaidDifficultyOptions)
                                    {
                                        <option value="@difficulty">@RosterDisplayText.RaidDifficulty(difficulty)</option>
                                    }
                                </select>
                            </label>

                            <label class="event-form-field event-form-field--wide">
                                Notes
                                <textarea
                                    @bind="createNotes"
                                    disabled="@createInProgress"
                                    rows="3"
                                    placeholder="Optional planning notes"></textarea>
                            </label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(createMessage))
                        {
                            <div class="event-status-message event-status-message--@createStatus" role="status">
                                @createMessage
                            </div>
                        }

                        <div class="event-create-form__actions">
                            <button type="submit" class="event-action" disabled="@createInProgress">
                                @(createInProgress ? "Creating..." : "Create Event")
                            </button>
                            <button type="button" class="event-action event-action--secondary" disabled="@createInProgress" @onclick="CancelCreateForm">
                                Reset
                            </button>
                        </div>
                    </form>
                </ContentPanel>

                <ContentPanel Title="Event Overview" Class="event-overview-panel">
                    <div class="event-list" role="list" aria-label="Raid events">
                        @foreach (var raidEvent in orderedEvents)
                        {
                            var isSelected = selectedEvent?.Id == raidEvent.Id;
                            var guild = FindGuild(raidEvent);
                            var raidTeam = FindRaidTeam(raidEvent);

                            <button
                                type="button"
                                class="@GetEventListItemClass(raidEvent, isSelected)"
                                @onclick="() => SelectEventAsync(raidEvent.Id)"
                                aria-pressed="@isSelected">
                                <span class="event-list-item__title">@raidEvent.Title</span>
                                <span class="event-list-item__time">@FormatDateTime(raidEvent.StartTime)</span>
                                <span class="event-list-item__context">
                                    <RaidTeamBadge Name="@GetRaidTeamName(raidTeam)" />
                                    <span>@GetGuildContext(guild)</span>
                                </span>
                                <span class="event-list-item__meta">
                                    <span class="event-difficulty">@RosterDisplayText.RaidDifficulty(raidEvent.Difficulty)</span>
                                    <span class="@GetEventStatusClass(raidEvent.Status)">@FormatEventStatus(raidEvent.Status)</span>
                                </span>
                            </button>
                        }
                    </div>
                </ContentPanel>
            </div>

            <ContentPanel Title="Event Detail" Class="event-detail-panel">
                @if (selectedEvent is null)
                {
                    <EmptyState
                        Title="No raid event selected."
                        Message="Choose a raid event from the overview to inspect its details." />
                }
                else
                {
                    var guild = FindGuild(selectedEvent);
                    var raidTeam = FindRaidTeam(selectedEvent);

                    <div class="event-detail-header">
                        <div>
                            <RaidTeamBadge Name="@GetRaidTeamName(raidTeam)" />
                            <h2>@selectedEvent.Title</h2>
                            <p>@GetGuildContext(guild)</p>
                        </div>
                        <div class="event-detail-header__meta">
                            <span class="@GetEventStatusClass(selectedEvent.Status, large: true)">@FormatEventStatus(selectedEvent.Status)</span>
                            <span class="event-difficulty event-difficulty--large">@RosterDisplayText.RaidDifficulty(selectedEvent.Difficulty)</span>
                            @if (!isEditingSelectedEvent && selectedEvent.Status == RaidEventStatus.Scheduled)
                            {
                                <button type="button" class="event-action event-action--secondary" @onclick="() => StartEdit(selectedEvent)">
                                    Edit
                                </button>
                                @if (!isConfirmingCancel)
                                {
                                    <button type="button" class="event-action event-action--danger" disabled="@cancelInProgress" @onclick="RequestCancel">
                                        Cancel event
                                    </button>
                                }
                            }
                            else if (selectedEvent.Status == RaidEventStatus.Cancelled)
                            {
                                <span class="event-edit-hint">This event is already cancelled.</span>
                            }
                        </div>
                    </div>

                    @if (isEditingSelectedEvent)
                    {
                        <form class="event-edit-form" @onsubmit="UpdateRaidEventAsync" @onsubmit:preventDefault>
                            <div class="event-create-form__grid">
                                <label class="event-form-field event-form-field--wide">
                                    Title
                                    <input
                                        @bind="editTitle"
                                        disabled="@editInProgress"
                                        placeholder="Weekly progression raid" />
                                </label>

                                <label class="event-form-field event-form-field--wide">
                                    Raid team
                                    <select @bind="editRaidTeamId" disabled="@editInProgress">
                                        @foreach (var option in RaidTeamOptions)
                                        {
                                            <option value="@option.RaidTeamId.ToString()">@FormatRaidTeamOption(option)</option>
                                        }
                                    </select>
                                </label>

                                <label class="event-form-field">
                                    Start date/time
                                    <input
                                        type="datetime-local"
                                        value="@editStartDateTime"
                                        @oninput="OnEditStartDateTimeChanged"
                                        disabled="@editInProgress" />
                                </label>

                                <label class="event-form-field">
                                    End date/time
                                    <input
                                        type="datetime-local"
                                        value="@editEndDateTime"
                                        @oninput="OnEditEndDateTimeChanged"
                                        disabled="@editInProgress" />
                                </label>

                                <label class="event-form-field">
                                    Instance
                                    <input
                                        @bind="editInstanceName"
                                        disabled="@editInProgress"
                                        placeholder="Manaforge Omega" />
                                </label>

                                <label class="event-form-field">
                                    Difficulty
                                    <select @bind="editDifficulty" disabled="@editInProgress">
                                        @foreach (var difficulty in RaidDifficultyOptions)
                                        {
                                            <option value="@difficulty">@RosterDisplayText.RaidDifficulty(difficulty)</option>
                                        }
                                    </select>
                                </label>

                                <label class="event-form-field event-form-field--wide">
                                    Notes
                                    <textarea
                                        @bind="editNotes"
                                        disabled="@editInProgress"
                                        rows="3"
                                        placeholder="Optional planning notes"></textarea>
                                </label>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(editMessage))
                            {
                                <div class="event-status-message event-status-message--@editStatus" role="status">
                                    @editMessage
                                </div>
                            }

                            <div class="event-create-form__actions">
                                <button type="submit" class="event-action" disabled="@editInProgress">
                                    @(editInProgress ? "Saving..." : "Save changes")
                                </button>
                                <button type="button" class="event-action event-action--secondary" disabled="@editInProgress" @onclick="DiscardEditChanges">
                                    Discard changes
                                </button>
                            </div>
                        </form>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(cancelMessage))
                        {
                            <div class="event-status-message event-status-message--@cancelStatus" role="status">
                                @cancelMessage
                            </div>
                        }

                        @if (selectedEvent.Status == RaidEventStatus.Scheduled && isConfirmingCancel)
                        {
                            <section class="event-cancel-confirm" aria-label="Confirm raid event cancellation">
                                <div>
                                    <strong>Cancel this raid event?</strong>
                                    <p>The event will stay visible with cancelled status.</p>
                                </div>
                                <div class="event-cancel-confirm__actions">
                                    <button type="button" class="event-action event-action--danger" disabled="@cancelInProgress" @onclick="CancelRaidEventAsync">
                                        @(cancelInProgress ? "Cancelling..." : "Confirm cancellation")
                                    </button>
                                    <button type="button" class="event-action event-action--secondary" disabled="@cancelInProgress" @onclick="DismissCancelConfirmation">
                                        Keep scheduled
                                    </button>
                                </div>
                            </section>
                        }

                        @if (!string.IsNullOrWhiteSpace(editMessage))
                        {
                            <div class="event-status-message event-status-message--@editStatus" role="status">
                                @editMessage
                            </div>
                        }

                        <div class="event-detail-grid">
                            <section class="event-detail-card">
                                <span>Raid team</span>
                                <strong>@GetRaidTeamName(raidTeam)</strong>
                            </section>
                            <section class="event-detail-card">
                                <span>Guild</span>
                                <strong>@GetGuildName(guild)</strong>
                                <small>@GetGuildRealm(guild)</small>
                            </section>
                            <section class="event-detail-card">
                                <span>Start</span>
                                <strong>@FormatDateTime(selectedEvent.StartTime)</strong>
                            </section>
                            <section class="event-detail-card">
                                <span>End</span>
                                <strong>@FormatOptionalDateTime(selectedEvent.EndTime)</strong>
                            </section>
                            <section class="event-detail-card">
                                <span>Duration</span>
                                <strong>@FormatDuration(selectedEvent)</strong>
                            </section>
                            <section class="event-detail-card">
                                <span>Instance</span>
                                <strong>@selectedEvent.InstanceName</strong>
                            </section>
                        </div>

                        <section class="event-notes-panel" aria-label="Raid event notes">
                            <h3>Notes</h3>
                            @if (string.IsNullOrWhiteSpace(selectedEvent.Notes))
                            {
                                <p class="muted">No notes for this raid event.</p>
                            }
                            else
                            {
                                <p>@selectedEvent.Notes</p>
                            }
                        </section>

                        <section class="event-signup-panel" aria-label="Raid event signup overview">
                            <div class="event-signup-panel__header">
                                <div>
                                    <h3>Signups</h3>
                                    <p>Manual signup overview for this raid event.</p>
                                </div>
                                @if (selectedEvent.Status == RaidEventStatus.Cancelled)
                                {
                                    <span class="event-signup-note">Cancelled events are not normally signup-capable.</span>
                                }
                            </div>

                            @if (signupsLoading)
                            {
                                <LoadingState Title="Loading signups" Message="Collecting signup status for the selected raid event." />
                            }
                            else if (!string.IsNullOrWhiteSpace(signupLoadFailure))
                            {
                                <EmptyState Title="Signup data could not be loaded." Message="@signupLoadFailure">
                                    <Actions>
                                        <button type="button" class="event-action event-action--secondary" @onclick="() => LoadSelectedEventSignupsAsync(selectedEvent.Id)">
                                            Try again
                                        </button>
                                    </Actions>
                                </EmptyState>
                            }
                            else if (loadedSignupRaidEventId != selectedEvent.Id)
                            {
                                <LoadingState Title="Loading signups" Message="Preparing signup status for the selected raid event." />
                            }
                            else
                            {
                                var missingResponseCount = GetMissingResponseCount(selectedEvent);

                                <div class="event-signup-summary-grid" aria-label="Signup summary">
                                    <section class="event-signup-summary-card event-signup-summary-card--signed">
                                        <span>Signed</span>
                                        <strong>@GetSignupStatusCount(RaidEventSignupStatus.Signed)</strong>
                                    </section>
                                    <section class="event-signup-summary-card event-signup-summary-card--tentative">
                                        <span>Tentative</span>
                                        <strong>@GetSignupStatusCount(RaidEventSignupStatus.Tentative)</strong>
                                    </section>
                                    <section class="event-signup-summary-card event-signup-summary-card--declined">
                                        <span>Declined</span>
                                        <strong>@GetSignupStatusCount(RaidEventSignupStatus.Declined)</strong>
                                    </section>
                                    <section class="event-signup-summary-card">
                                        <span>Missing response</span>
                                        <strong>@FormatOptionalCount(missingResponseCount)</strong>
                                    </section>
                                </div>

                                <div class="event-signup-composition" aria-label="Signup role composition">
                                    <span>Role composition</span>
                                    <strong>Tank @GetSignupRoleCount(CharacterRole.Tank)</strong>
                                    <strong>Healer @GetSignupRoleCount(CharacterRole.Healer)</strong>
                                    <strong>DPS @GetSignupRoleCount(CharacterRole.Damage)</strong>
                                </div>

                                @if (selectedEventSignups.Count == 0)
                                {
                                    <EmptyState
                                        Title="No signups yet."
                                        Message="This raid event has no stored signup responses yet." />
                                }
                                else
                                {
                                    <div class="event-signup-list" role="list" aria-label="Raid event signups">
                                        @foreach (var signup in selectedEventSignups)
                                        {
                                            <article class="event-signup-row" role="listitem">
                                                <div class="event-signup-row__identity">
                                                    <strong>@signup.PlayerDisplayName</strong>
                                                    <span>
                                                        @(signup.HasMainCharacter && !string.IsNullOrWhiteSpace(signup.MainCharacterName)
                                                            ? signup.MainCharacterName
                                                            : "No main character")
                                                    </span>
                                                    <MainAltBadge HasMainCharacter="@signup.HasMainCharacter" />
                                                </div>
                                                <div class="event-signup-row__badges">
                                                    <CharacterClassBadge Value="@signup.CharacterClass" />
                                                    <CharacterRoleBadge Value="@signup.Role" />
                                                    <GuildRankBadge Value="@signup.GuildRank" />
                                                    @if (signup.AdditionalRoles.Count == 0)
                                                    {
                                                        <span class="event-signup-muted">No additional roles</span>
                                                    }
                                                    else
                                                    {
                                                        @foreach (var role in signup.AdditionalRoles)
                                                        {
                                                            <GuildRoleBadge Value="@role" />
                                                        }
                                                    }
                                                </div>
                                                <span class="@GetSignupStatusClass(signup.Status)">@FormatSignupStatus(signup.Status)</span>
                                            </article>
                                        }
                                    </div>
                                }
                            }
                        </section>
                    }
                }
            </ContentPanel>
        </section>
    }
</main>

@code {
    private IReadOnlyList<RaidEventDto> raidEvents = [];
    private IReadOnlyList<GuildDto> guilds = [];
    private bool isLoading = true;
    private string? loadFailure;
    private bool createInProgress;
    private string? createMessage;
    private string createStatus = "success";
    private bool editInProgress;
    private bool isEditingSelectedEvent;
    private string? editMessage;
    private string editStatus = "success";
    private bool cancelInProgress;
    private bool isConfirmingCancel;
    private string? cancelMessage;
    private string cancelStatus = "success";
    private IReadOnlyList<RaidEventSignupDto> selectedEventSignups = [];
    private Guid? loadedSignupRaidEventId;
    private bool signupsLoading;
    private string? signupLoadFailure;
    private Guid? selectedRaidEventId;
    private string createTitle = string.Empty;
    private string createRaidTeamId = string.Empty;
    private string createStartDateTime = string.Empty;
    private string createEndDateTime = string.Empty;
    private string createInstanceName = string.Empty;
    private RaidDifficulty createDifficulty = RaidDifficulty.Normal;
    private string createNotes = string.Empty;
    private string editTitle = string.Empty;
    private string editRaidTeamId = string.Empty;
    private string editStartDateTime = string.Empty;
    private string editEndDateTime = string.Empty;
    private string editInstanceName = string.Empty;
    private RaidDifficulty editDifficulty = RaidDifficulty.Normal;
    private string editNotes = string.Empty;

    private static readonly IReadOnlyList<RaidDifficulty> RaidDifficultyOptions =
    [
        RaidDifficulty.LookingForRaid,
        RaidDifficulty.Normal,
        RaidDifficulty.Heroic,
        RaidDifficulty.Mythic
    ];

    private IReadOnlyList<RaidEventDto> OrderedRaidEvents
        => raidEvents
            .OrderBy(raidEvent => raidEvent.StartTime)
            .ThenBy(raidEvent => raidEvent.Title, StringComparer.OrdinalIgnoreCase)
            .ThenBy(raidEvent => raidEvent.Id)
            .ToList();

    private RaidEventDto? SelectedEvent
        => raidEvents.FirstOrDefault(raidEvent => raidEvent.Id == selectedRaidEventId);

    private bool HasAnyRaidTeams
        => guilds.Any(guild => guild.RaidTeams.Count > 0);

    private int RaidTeamsWithEventsCount
        => raidEvents
            .Select(raidEvent => raidEvent.RaidTeamId)
            .Distinct()
            .Count();

    private IReadOnlyList<RaidTeamOption> RaidTeamOptions
        => guilds
            .SelectMany(guild => guild.RaidTeams.Select(raidTeam => new RaidTeamOption(
                guild.Id,
                raidTeam.Id,
                raidTeam.Name,
                guild.Name,
                guild.Region,
                guild.Realm)))
            .OrderBy(option => option.GuildName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(option => option.RaidTeamName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(option => option.RaidTeamId)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadRaidEventsAsync();
    }

    private async Task LoadRaidEventsAsync()
    {
        isLoading = true;
        loadFailure = null;

        try
        {
            guilds = await ListGuildsHandler.HandleAsync(new ListGuildsQuery());
            raidEvents = await ListRaidEventsHandler.HandleAsync(new ListRaidEventsQuery());
            EnsureSelection();
            EnsureCreateRaidTeamSelection();
            EnsureEditStateIsValid();
            await LoadSelectedEventSignupsAsync(selectedRaidEventId);
        }
        catch
        {
            guilds = [];
            raidEvents = [];
            selectedRaidEventId = null;
            selectedEventSignups = [];
            loadedSignupRaidEventId = null;
            signupsLoading = false;
            signupLoadFailure = null;
            StopEdit(clearMessage: true);
            ResetCancelState(clearMessage: true);
            loadFailure = "An unexpected technical failure occurred while loading raid events.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadRaidEventsAsync(Guid? preferredRaidEventId)
    {
        selectedRaidEventId = preferredRaidEventId;
        await LoadRaidEventsAsync();
    }

    private async Task CreateRaidEventAsync()
    {
        createMessage = null;

        if (!TryCreateCommand(out var command))
        {
            return;
        }

        createInProgress = true;

        try
        {
            var result = await CreateRaidEventHandler.HandleAsync(command);
            if (result.IsFailure)
            {
                ShowCreateFailure(result.Failure!);
                return;
            }

            var createdEvent = result.Value ?? throw new InvalidOperationException("Successful create raid event result did not include a value.");
            ShowCreateSuccess($"Created {createdEvent.Title}.");
            ResetCreateForm(clearMessage: false);
            await LoadRaidEventsAsync(createdEvent.Id);
        }
        catch
        {
            ShowCreateTechnicalFailure("An unexpected technical failure occurred while creating the raid event.");
        }
        finally
        {
            createInProgress = false;
        }
    }

    private async Task UpdateRaidEventAsync()
    {
        editMessage = null;

        if (!TryCreateUpdateCommand(out var command))
        {
            return;
        }

        editInProgress = true;

        try
        {
            var result = await UpdateRaidEventHandler.HandleAsync(command);
            if (result.IsFailure)
            {
                ShowEditFailure(result.Failure!);
                return;
            }

            var updatedEvent = result.Value ?? throw new InvalidOperationException("Successful update raid event result did not include a value.");
            ShowEditSuccess($"Updated {updatedEvent.Title}.");
            StopEdit(clearMessage: false);
            await LoadRaidEventsAsync(updatedEvent.Id);
        }
        catch
        {
            ShowEditTechnicalFailure("An unexpected technical failure occurred while updating the raid event.");
        }
        finally
        {
            editInProgress = false;
        }
    }

    private async Task CancelRaidEventAsync()
    {
        cancelMessage = null;

        var selectedEvent = SelectedEvent;
        if (selectedEvent is null)
        {
            ShowCancelFailure(new Failure(FailureType.NotFound, "Selected raid event was not found."));
            isConfirmingCancel = false;
            return;
        }

        cancelInProgress = true;

        try
        {
            var result = await CancelRaidEventHandler.HandleAsync(new CancelRaidEventCommand(selectedEvent.Id));
            if (result.IsFailure)
            {
                ShowCancelFailure(result.Failure!);
                isConfirmingCancel = false;
                return;
            }

            var cancelledEvent = result.Value ?? throw new InvalidOperationException("Successful cancel raid event result did not include a value.");
            StopEdit(clearMessage: true);
            isConfirmingCancel = false;
            ShowCancelSuccess($"Cancelled {cancelledEvent.Title}.");
            await LoadRaidEventsAsync(cancelledEvent.Id);
        }
        catch
        {
            ShowCancelTechnicalFailure("An unexpected technical failure occurred while cancelling the raid event.");
            isConfirmingCancel = false;
        }
        finally
        {
            cancelInProgress = false;
        }
    }

    private async Task SelectEventAsync(Guid raidEventId)
    {
        if (selectedRaidEventId != raidEventId)
        {
            StopEdit(clearMessage: true);
            ResetCancelState(clearMessage: true);
        }

        selectedRaidEventId = raidEventId;
        await LoadSelectedEventSignupsAsync(raidEventId);
    }

    private async Task LoadSelectedEventSignupsAsync(Guid? raidEventId)
    {
        signupLoadFailure = null;

        if (!raidEventId.HasValue)
        {
            selectedEventSignups = [];
            loadedSignupRaidEventId = null;
            signupsLoading = false;
            return;
        }

        var requestedRaidEventId = raidEventId.Value;
        signupsLoading = true;
        if (selectedRaidEventId == requestedRaidEventId)
        {
            selectedEventSignups = [];
            loadedSignupRaidEventId = null;
        }

        try
        {
            var signups = await ListRaidEventSignupsHandler.HandleAsync(new ListRaidEventSignupsQuery(requestedRaidEventId));
            if (selectedRaidEventId == requestedRaidEventId)
            {
                selectedEventSignups = signups;
                loadedSignupRaidEventId = requestedRaidEventId;
            }
        }
        catch
        {
            if (selectedRaidEventId == requestedRaidEventId)
            {
                selectedEventSignups = [];
                loadedSignupRaidEventId = requestedRaidEventId;
                signupLoadFailure = "An unexpected technical failure occurred while loading raid event signups.";
            }
        }
        finally
        {
            if (selectedRaidEventId == requestedRaidEventId)
            {
                signupsLoading = false;
            }
        }
    }

    private void EnsureSelection()
    {
        if (raidEvents.Count == 0)
        {
            selectedRaidEventId = null;
            return;
        }

        if (selectedRaidEventId is null || raidEvents.All(raidEvent => raidEvent.Id != selectedRaidEventId.Value))
        {
            selectedRaidEventId = OrderedRaidEvents.First().Id;
            StopEdit(clearMessage: true);
            ResetCancelState(clearMessage: true);
        }
    }

    private void EnsureCreateRaidTeamSelection()
    {
        var options = RaidTeamOptions;
        if (options.Count == 0)
        {
            createRaidTeamId = string.Empty;
            return;
        }

        if (!Guid.TryParse(createRaidTeamId, out var selectedRaidTeamId)
            || options.All(option => option.RaidTeamId != selectedRaidTeamId))
        {
            createRaidTeamId = options.First().RaidTeamId.ToString();
        }
    }

    private bool TryCreateCommand(out CreateRaidEventCommand command)
    {
        command = default!;

        if (!Guid.TryParse(createRaidTeamId, out var raidTeamId))
        {
            ShowCreateFailure(new Failure(FailureType.Validation, "Select a raid team before creating a raid event."));
            return false;
        }

        var option = RaidTeamOptions.FirstOrDefault(candidate => candidate.RaidTeamId == raidTeamId);
        if (option is null)
        {
            ShowCreateFailure(new Failure(FailureType.NotFound, "Selected raid team context was not found."));
            return false;
        }

        if (!TryParseLocalDateTime(createStartDateTime, out var startTime))
        {
            ShowCreateFailure(new Failure(FailureType.Validation, "Start date and time must be set with a valid date and time."));
            return false;
        }

        DateTimeOffset? endTime = null;
        if (!string.IsNullOrWhiteSpace(createEndDateTime))
        {
            if (!TryParseLocalDateTime(createEndDateTime, out var parsedEndTime))
            {
                ShowCreateFailure(new Failure(FailureType.Validation, "End date and time must be a valid date and time."));
                return false;
            }

            endTime = parsedEndTime;
        }

        command = new CreateRaidEventCommand(
            option.GuildId,
            option.RaidTeamId,
            createTitle,
            startTime,
            endTime,
            createInstanceName,
            createDifficulty,
            createNotes);

        return true;
    }

    private bool TryCreateUpdateCommand(out UpdateRaidEventCommand command)
    {
        command = default!;

        var selectedEvent = SelectedEvent;
        if (selectedEvent is null)
        {
            ShowEditFailure(new Failure(FailureType.NotFound, "Selected raid event was not found."));
            return false;
        }

        if (!Guid.TryParse(editRaidTeamId, out var raidTeamId))
        {
            ShowEditFailure(new Failure(FailureType.Validation, "Select a raid team before updating the raid event."));
            return false;
        }

        var option = RaidTeamOptions.FirstOrDefault(candidate => candidate.RaidTeamId == raidTeamId);
        if (option is null)
        {
            ShowEditFailure(new Failure(FailureType.NotFound, "Selected raid team context was not found."));
            return false;
        }

        if (!TryParseLocalDateTime(editStartDateTime, out var startTime))
        {
            ShowEditFailure(new Failure(FailureType.Validation, "Start date and time must be set with a valid date and time."));
            return false;
        }

        DateTimeOffset? endTime = null;
        if (!string.IsNullOrWhiteSpace(editEndDateTime))
        {
            if (!TryParseLocalDateTime(editEndDateTime, out var parsedEndTime))
            {
                ShowEditFailure(new Failure(FailureType.Validation, "End date and time must be a valid date and time."));
                return false;
            }

            endTime = parsedEndTime;
        }

        command = new UpdateRaidEventCommand(
            selectedEvent.Id,
            option.GuildId,
            option.RaidTeamId,
            editTitle,
            startTime,
            endTime,
            editInstanceName,
            editDifficulty,
            editNotes);

        return true;
    }

    private void CancelCreateForm()
    {
        ResetCreateForm(clearMessage: true);
    }

    private void StartEdit(RaidEventDto raidEvent)
    {
        ResetCancelState(clearMessage: true);

        if (raidEvent.Status != RaidEventStatus.Scheduled)
        {
            ShowEditFailure(new Failure(FailureType.BusinessRule, "Cancelled raid events cannot be updated."));
            return;
        }

        selectedRaidEventId = raidEvent.Id;
        editTitle = raidEvent.Title;
        editRaidTeamId = raidEvent.RaidTeamId.ToString();
        editStartDateTime = FormatDateTimeLocalValue(raidEvent.StartTime);
        editEndDateTime = raidEvent.EndTime.HasValue ? FormatDateTimeLocalValue(raidEvent.EndTime.Value) : string.Empty;
        editInstanceName = raidEvent.InstanceName;
        editDifficulty = raidEvent.Difficulty;
        editNotes = raidEvent.Notes;
        editMessage = null;
        editStatus = "success";
        isEditingSelectedEvent = true;
    }

    private void DiscardEditChanges()
    {
        StopEdit(clearMessage: true);
    }

    private void RequestCancel()
    {
        editMessage = null;
        cancelMessage = null;
        isConfirmingCancel = true;
    }

    private void DismissCancelConfirmation()
    {
        ResetCancelState(clearMessage: true);
    }

