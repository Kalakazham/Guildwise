@page "/"
@page "/roster-setup"
@rendermode InteractiveServer

@using Guildwise.Application.Characters.CreateCharacter
@using Guildwise.Application.Characters.SetMainCharacter
@using Guildwise.Application.Common.Results
@using Guildwise.Application.Contracts.Characters
@using Guildwise.Application.Contracts.Guilds
@using Guildwise.Application.Contracts.Players
@using Guildwise.Application.Contracts.RaidTeams
@using Guildwise.Application.GuildMembers.AddPlayerToGuild
@using Guildwise.Application.Guilds.CreateGuild
@using Guildwise.Application.Guilds.ListGuilds
@using Guildwise.Application.Players.CreatePlayer
@using Guildwise.Application.Players.ListPlayers
@using Guildwise.Application.RaidTeams.AddPlayerToRaidTeam
@using Guildwise.Application.RaidTeams.CreateRaidTeam
@using Guildwise.Application.RaidTeams.ListRaidTeamsForGuild
@using Guildwise.Domain
@inject CreateGuildHandler CreateGuildHandler
@inject ListGuildsHandler ListGuildsHandler
@inject CreatePlayerHandler CreatePlayerHandler
@inject ListPlayersHandler ListPlayersHandler
@inject CreateCharacterHandler CreateCharacterHandler
@inject SetMainCharacterHandler SetMainCharacterHandler
@inject CreateRaidTeamHandler CreateRaidTeamHandler
@inject ListRaidTeamsForGuildHandler ListRaidTeamsForGuildHandler
@inject AddPlayerToGuildHandler AddPlayerToGuildHandler
@inject AddPlayerToRaidTeamHandler AddPlayerToRaidTeamHandler

<PageTitle>Roster Setup</PageTitle>

<main class="setup-page">
    <section class="setup-header">
        <div>
            <p class="eyebrow">Guildwise verification</p>
            <h1>Manual roster setup</h1>
        </div>
        <button type="button" class="secondary-action" @onclick="SeedSampleRoster">Seed sample roster</button>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-message @statusKind">@statusMessage</div>
    }

    <section class="workflow-grid">
        <form class="setup-panel" @onsubmit="CreateGuild" @onsubmit:preventDefault="true">
            <h2>Guild</h2>
            <label>
                Name
                <input @bind="guildName" />
            </label>
            <label>
                Region
                <input @bind="guildRegion" />
            </label>
            <label>
                Realm
                <input @bind="guildRealm" />
            </label>
            <button type="submit">Create guild</button>
        </form>

        <form class="setup-panel" @onsubmit="CreatePlayer" @onsubmit:preventDefault="true">
            <h2>Player</h2>
            <label>
                Display name
                <input @bind="playerName" />
            </label>
            <button type="submit">Create player</button>
        </form>

        <form class="setup-panel" @onsubmit="CreateCharacter" @onsubmit:preventDefault="true">
            <h2>Character</h2>
            <label>
                Player
                <select @bind="selectedPlayerId">
                    <option value="">Select player</option>
                    @foreach (var player in players)
                    {
                        <option value="@player.Id">@player.DisplayName</option>
                    }
                </select>
            </label>
            <label>
                Name
                <input @bind="characterName" />
            </label>
            <label>
                Region
                <input @bind="characterRegion" />
            </label>
            <label>
                Realm
                <input @bind="characterRealm" />
            </label>
            <label>
                Class and specialization
                <select @bind="selectedCharacterPresetName">
                    @foreach (var preset in characterPresets)
                    {
                        <option value="@preset.Name">@preset.Name</option>
                    }
                </select>
            </label>
            <button type="submit">Create and set main</button>
        </form>

        <form class="setup-panel" @onsubmit="CreateRaidTeam" @onsubmit:preventDefault="true">
            <h2>Raid team</h2>
            <label>
                Guild
                <select @bind="selectedGuildId">
                    <option value="">Select guild</option>
                    @foreach (var guild in guilds)
                    {
                        <option value="@guild.Id">@guild.Name</option>
                    }
                </select>
            </label>
            <label>
                Name
                <input @bind="raidTeamName" />
            </label>
            <button type="submit">Create raid team</button>
        </form>

        <form class="setup-panel" @onsubmit="AddPlayerToGuild" @onsubmit:preventDefault="true">
            <h2>Guild member</h2>
            <label>
                Guild
                <select @bind="selectedGuildId">
                    <option value="">Select guild</option>
                    @foreach (var guild in guilds)
                    {
                        <option value="@guild.Id">@guild.Name</option>
                    }
                </select>
            </label>
            <label>
                Player
                <select @bind="selectedPlayerId">
                    <option value="">Select player</option>
                    @foreach (var player in players)
                    {
                        <option value="@player.Id">@player.DisplayName</option>
                    }
                </select>
            </label>
            <button type="submit">Add to guild</button>
        </form>

        <form class="setup-panel" @onsubmit="AddPlayerToRaidTeam" @onsubmit:preventDefault="true">
            <h2>Roster</h2>
            <label>
                Raid team
                <select @bind="selectedRaidTeamId">
                    <option value="">Select raid team</option>
                    @foreach (var raidTeam in raidTeams)
                    {
                        <option value="@raidTeam.Id">@raidTeam.Name</option>
                    }
                </select>
            </label>
            <label>
                Player
                <select @bind="selectedPlayerId">
                    <option value="">Select player</option>
                    @foreach (var player in players)
                    {
                        <option value="@player.Id">@player.DisplayName</option>
                    }
                </select>
            </label>
            <button type="submit">Add to raid team</button>
        </form>
    </section>

    <section class="roster-section">
        <div class="section-heading">
            <h2>Roster list</h2>
            <button type="button" class="secondary-action" @onclick="RefreshDataAsync">Refresh</button>
        </div>

        @if (guilds.Count == 0)
        {
            <p class="empty-state">No guild has been created yet.</p>
        }
        else if (raidTeams.Count == 0)
        {
            <p class="empty-state">Create a raid team for the selected guild.</p>
        }
        else
        {
            <div class="roster-grid">
                @foreach (var raidTeam in raidTeams)
                {
                    <article class="roster-team">
                        <h3>@raidTeam.Name</h3>
                        @if (raidTeam.Members.Count == 0)
                        {
                            <p class="empty-state">No players assigned.</p>
                        }
                        else
                        {
                            <table>
                                <thead>
                                <tr>
                                    <th>Player</th>
                                    <th>Main character</th>
                                    <th>Role</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var member in raidTeam.Members)
                                {
                                    var player = players.FirstOrDefault(existing => existing.Id == member.PlayerId);
                                    var mainCharacter = GetMainCharacter(player);

                                    <tr>
                                        <td>@(player?.DisplayName ?? "Unknown player")</td>
                                        <td>@FormatCharacter(mainCharacter)</td>
                                        <td>@(mainCharacter?.Role.ToString() ?? "-")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        }
                    </article>
                }
            </div>
        }
    </section>
</main>