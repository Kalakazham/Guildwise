@page "/"
@page "/roster-setup"
@rendermode InteractiveServer

@using Guildwise.Application.Characters.CreateCharacter
@using Guildwise.Application.Characters.SetMainCharacter
@using Guildwise.Application.Common.Results
@using Guildwise.Application.Contracts.Characters
@using Guildwise.Application.Contracts.Guilds
@using Guildwise.Application.Contracts.Players
@using Guildwise.Application.Contracts.RaidTeams
@using Guildwise.Application.GuildMembers.AddPlayerToGuild
@using Guildwise.Application.Guilds.CreateGuild
@using Guildwise.Application.Guilds.ListGuilds
@using Guildwise.Application.Players.CreatePlayer
@using Guildwise.Application.Players.ListPlayers
@using Guildwise.Application.RaidTeams.AddPlayerToRaidTeam
@using Guildwise.Application.RaidTeams.CreateRaidTeam
@using Guildwise.Application.RaidTeams.ListRaidTeamsForGuild
@using Guildwise.Domain
@inject CreateGuildHandler CreateGuildHandler
@inject ListGuildsHandler ListGuildsHandler
@inject CreatePlayerHandler CreatePlayerHandler
@inject ListPlayersHandler ListPlayersHandler
@inject CreateCharacterHandler CreateCharacterHandler
@inject SetMainCharacterHandler SetMainCharacterHandler
@inject CreateRaidTeamHandler CreateRaidTeamHandler
@inject ListRaidTeamsForGuildHandler ListRaidTeamsForGuildHandler
@inject AddPlayerToGuildHandler AddPlayerToGuildHandler
@inject AddPlayerToRaidTeamHandler AddPlayerToRaidTeamHandler

<PageTitle>Roster Setup</PageTitle>

<main class="setup-page">
    <section class="setup-header">
        <div>
            <p class="eyebrow">Guildwise verification</p>
            <h1>Manual roster setup</h1>
        </div>
        <button type="button" class="secondary-action" @onclick="SeedSampleRoster">Seed sample roster</button>
    </section>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-message @statusKind">@statusMessage</div>
    }

    <section class="workflow-grid">
        <form class="setup-panel" @onsubmit="CreateGuild" @onsubmit:preventDefault="true">
            <h2>Guild</h2>
            <label>
                Name
                <input @bind="guildName" />
            </label>
            <label>
                Region
                <input @bind="guildRegion" />
            </label>
            <label>
                Realm
                <input @bind="guildRealm" />
            </label>
            <button type="submit">Create guild</button>
        </form>

        <form class="setup-panel" @onsubmit="CreatePlayer" @onsubmit:preventDefault="true">
            <h2>Player</h2>
            <label>
                Display name
                <input @bind="playerName" />
            </label>
            <button type="submit">Create player</button>
        </form>

        <form class="setup-panel" @onsubmit="CreateCharacter" @onsubmit:preventDefault="true">
            <h2>Character</h2>
            <label>
                Player
                <select @bind="selectedPlayerId">
                    <option value="">Select player</option>
                    @foreach (var player in players)
                    {
                        <option value="@player.Id">@player.DisplayName</option>
                    }
                </select>
            </label>
            <label>
                Name
                <input @bind="characterName" />
            </label>
            <label>
                Region
                <input @bind="characterRegion" />
            </label>
            <label>
                Realm
                <input @bind="characterRealm" />
            </label>
            <label>
                Class and specialization
                <select @bind="selectedCharacterPresetName">
                    @foreach (var preset in characterPresets)
                    {
                        <option value="@preset.Name">@preset.Name</option>
                    }
                </select>
            </label>
            <button type="submit">Create and set main</button>
        </form>

        <form class="setup-panel" @onsubmit="CreateRaidTeam" @onsubmit:preventDefault="true">
            <h2>Raid team</h2>
            <label>
                Guild
                <select @bind="selectedGuildId">
                    <option value="">Select guild</option>
                    @foreach (var guild in guilds)
                    {
                        <option value="@guild.Id">@guild.Name</option>
                    }
                </select>
            </label>
            <label>
                Name
                <input @bind="raidTeamName" />
            </label>
            <button type="submit">Create raid team</button>
        </form>

        <form class="setup-panel" @onsubmit="AddPlayerToGuild" @onsubmit:preventDefault="true">
            <h2>Guild member</h2>
            <label>
                Guild
                <select @bind="selectedGuildId">
                    <option value="">Select guild</option>
                    @foreach (var guild in guilds)
                    {
                        <option value="@guild.Id">@guild.Name</option>
                    }
                </select>
            </label>
            <label>
                Player
                <select @bind="selectedPlayerId">
                    <option value="">Select player</option>
                    @foreach (var player in players)
                    {
                        <option value="@player.Id">@player.DisplayName</option>
                    }
                </select>
            </label>
            <button type="submit">Add to guild</button>
        </form>

        <form class="setup-panel" @onsubmit="AddPlayerToRaidTeam" @onsubmit:preventDefault="true">
            <h2>Roster</h2>
            <label>
                Raid team
                <select @bind="selectedRaidTeamId">
                    <option value="">Select raid team</option>
                    @foreach (var raidTeam in raidTeams)
                    {
                        <option value="@raidTeam.Id">@raidTeam.Name</option>
                    }
                </select>
            </label>
            <label>
                Player
                <select @bind="selectedPlayerId">
                    <option value="">Select player</option>
                    @foreach (var player in players)
                    {
                        <option value="@player.Id">@player.DisplayName</option>
                    }
                </select>
            </label>
            <button type="submit">Add to raid team</button>
        </form>
    </section>

    <section class="roster-section">
        <div class="section-heading">
            <h2>Roster list</h2>
            <button type="button" class="secondary-action" @onclick="RefreshDataAsync">Refresh</button>
        </div>

        @if (guilds.Count == 0)
        {
            <p class="empty-state">No guild has been created yet.</p>
        }
        else if (raidTeams.Count == 0)
        {
            <p class="empty-state">Create a raid team for the selected guild.</p>
        }
        else
        {
            <div class="roster-grid">
                @foreach (var raidTeam in raidTeams)
                {
                    <article class="roster-team">
                        <h3>@raidTeam.Name</h3>
                        @if (raidTeam.Members.Count == 0)
                        {
                            <p class="empty-state">No players assigned.</p>
                        }
                        else
                        {
                            <table>
                                <thead>
                                <tr>
                                    <th>Player</th>
                                    <th>Main character</th>
                                    <th>Role</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var member in raidTeam.Members)
                                {
                                    var player = players.FirstOrDefault(existing => existing.Id == member.PlayerId);
                                    var mainCharacter = GetMainCharacter(player);

                                    <tr>
                                        <td>@(player?.DisplayName ?? "Unknown player")</td>
                                        <td>@FormatCharacter(mainCharacter)</td>
                                        <td>@(mainCharacter?.Role.ToString() ?? "-")</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        }
                    </article>
                }
            </div>
        }
    </section>
</main>

@code {
    private readonly IReadOnlyList<CharacterPreset> characterPresets =
    [
        new("Retribution Paladin", CharacterClass.Paladin, CharacterSpecialization.PaladinRetribution, CharacterRole.Damage),
        new("Protection Warrior", CharacterClass.Warrior, CharacterSpecialization.WarriorProtection, CharacterRole.Tank),
        new("Restoration Shaman", CharacterClass.Shaman, CharacterSpecialization.ShamanRestoration, CharacterRole.Healer),
        new("Frost Mage", CharacterClass.Mage, CharacterSpecialization.MageFrost, CharacterRole.Damage)
    ];

    private List<GuildDto> guilds = [];
    private List<PlayerDto> players = [];
    private List<RaidTeamDto> raidTeams = [];

    private string guildName = "Guildwise";
    private string guildRegion = "EU";
    private string guildRealm = "Draenor";
    private string playerName = "Myrmi";
    private string characterName = "Alysa";
    private string characterRegion = "EU";
    private string characterRealm = "Draenor";
    private string raidTeamName = "Team One";
    private string selectedCharacterPresetName = "Retribution Paladin";
    private string? selectedGuildId;
    private string? selectedPlayerId;
    private string? selectedRaidTeamId;
    private string? statusMessage;
    private string statusKind = "info";

    protected override async Task OnInitializedAsync()
    {
        await RefreshDataAsync();
    }

    private async Task CreateGuild()
    {
        await RunActionAsync(async () =>
        {
            var guild = await CreateGuildHandler.HandleAsync(new CreateGuildCommand(guildName, guildRegion, guildRealm));
            selectedGuildId = guild.Id.ToString();
            statusMessage = $"Created guild {guild.Name}.";
        });
    }

    private async Task CreatePlayer()
    {
        await RunActionAsync(async () =>
        {
            var player = await CreatePlayerHandler.HandleAsync(new CreatePlayerCommand(playerName));
            selectedPlayerId = player.Id.ToString();
            statusMessage = $"Created player {player.DisplayName}.";
        });
    }

    private async Task CreateCharacter()
    {
        await RunActionAsync(async () =>
        {
            var playerId = RequireGuid(selectedPlayerId, "Select a player first.");
            var preset = characterPresets.Single(existing => existing.Name == selectedCharacterPresetName);
            var character = Unwrap(await CreateCharacterHandler.HandleAsync(new CreateCharacterCommand(
                playerId,
                characterName,
                characterRegion,
                characterRealm,
                preset.CharacterClass,
                preset.Specialization,
                preset.Role)));

            EnsureSuccess(await SetMainCharacterHandler.HandleAsync(new SetMainCharacterCommand(playerId, character.Id)));
            statusMessage = $"Created {character.Name} and set it as main.";
        });
    }

    private async Task CreateRaidTeam()
    {
        await RunActionAsync(async () =>
        {
            var guildId = RequireGuid(selectedGuildId, "Select a guild first.");
            var raidTeam = await CreateRaidTeamHandler.HandleAsync(new CreateRaidTeamCommand(guildId, raidTeamName));
            selectedRaidTeamId = raidTeam.Id.ToString();
            statusMessage = $"Created raid team {raidTeam.Name}.";
        });
    }

    private async Task AddPlayerToGuild()
    {
        await RunActionAsync(async () =>
        {
            var guildId = RequireGuid(selectedGuildId, "Select a guild first.");
            var playerId = RequireGuid(selectedPlayerId, "Select a player first.");

            EnsureSuccess(await AddPlayerToGuildHandler.HandleAsync(new AddPlayerToGuildCommand(guildId, playerId, GuildRank.Member)));
            statusMessage = "Added player to guild.";
        });
    }

    private async Task AddPlayerToRaidTeam()
    {
        await RunActionAsync(async () =>
        {
            var guildId = RequireGuid(selectedGuildId, "Select a guild first.");
            var raidTeamId = RequireGuid(selectedRaidTeamId, "Select a raid team first.");
            var playerId = RequireGuid(selectedPlayerId, "Select a player first.");

            EnsureSuccess(await AddPlayerToRaidTeamHandler.HandleAsync(new AddPlayerToRaidTeamCommand(guildId, raidTeamId, playerId)));
            statusMessage = "Added player to raid team.";
        });
    }

    private async Task SeedSampleRoster()
    {
        await RunActionAsync(async () =>
        {
            var suffix = DateTimeOffset.UtcNow.ToUnixTimeSeconds().ToString();
            var guild = await CreateGuildHandler.HandleAsync(new CreateGuildCommand($"Guildwise {suffix}", "EU", "Draenor"));
            var player = await CreatePlayerHandler.HandleAsync(new CreatePlayerCommand($"Myrmi {suffix}"));
            var character = Unwrap(await CreateCharacterHandler.HandleAsync(new CreateCharacterCommand(
                player.Id,
                $"Alysa{suffix[^4..]}",
                "EU",
                "Draenor",
                CharacterClass.Paladin,
                CharacterSpecialization.PaladinRetribution,
                CharacterRole.Damage)));

            EnsureSuccess(await SetMainCharacterHandler.HandleAsync(new SetMainCharacterCommand(player.Id, character.Id)));
            var raidTeam = await CreateRaidTeamHandler.HandleAsync(new CreateRaidTeamCommand(guild.Id, "Team One"));
            EnsureSuccess(await AddPlayerToGuildHandler.HandleAsync(new AddPlayerToGuildCommand(guild.Id, player.Id, GuildRank.Member)));
            EnsureSuccess(await AddPlayerToRaidTeamHandler.HandleAsync(new AddPlayerToRaidTeamCommand(guild.Id, raidTeam.Id, player.Id)));

            selectedGuildId = guild.Id.ToString();
            selectedPlayerId = player.Id.ToString();
            selectedRaidTeamId = raidTeam.Id.ToString();
            statusMessage = "Seeded a complete roster flow.";
        });
    }

    private async Task RunActionAsync(Func<Task> action)
    {
        try
        {
            await action();
            statusKind = "success";
        }
        catch (Exception exception) when (exception is InvalidOperationException or ArgumentException)
        {
            statusMessage = exception.Message;
            statusKind = "error";
        }

        await RefreshDataAsync();
    }

    private async Task RefreshDataAsync()
    {
        guilds = (await ListGuildsHandler.HandleAsync(new ListGuildsQuery())).ToList();
        players = (await ListPlayersHandler.HandleAsync(new ListPlayersQuery())).ToList();

        if (!Guid.TryParse(selectedGuildId, out var guildId) || guilds.All(guild => guild.Id != guildId))
        {
            selectedGuildId = guilds.Count == 0 ? null : guilds[0].Id.ToString();
            guildId = guilds.Count == 0 ? Guid.Empty : guilds[0].Id;
        }

        raidTeams = guildId == Guid.Empty
            ? []
            : (await ListRaidTeamsForGuildHandler.HandleAsync(new ListRaidTeamsForGuildQuery(guildId))).ToList();

        if (!Guid.TryParse(selectedPlayerId, out _) && players.Count > 0)
        {
            selectedPlayerId = players[0].Id.ToString();
        }

        if (!Guid.TryParse(selectedRaidTeamId, out var raidTeamId) || raidTeams.All(raidTeam => raidTeam.Id != raidTeamId))
        {
            selectedRaidTeamId = raidTeams.Count == 0 ? null : raidTeams[0].Id.ToString();
        }
    }

    private static Guid RequireGuid(string? value, string message)
        => Guid.TryParse(value, out var id) ? id : throw new InvalidOperationException(message);

    private static T Unwrap<T>(Result<T> result)
        => result.IsSuccess && result.Value is not null
            ? result.Value
            : throw new InvalidOperationException(result.Failure?.Message ?? "Application command failed.");

    private static void EnsureSuccess(Result result)
    {
        if (result.IsFailure)
        {
            throw new InvalidOperationException(result.Failure?.Message ?? "Application command failed.");
        }
    }

    private static void EnsureSuccess<T>(Result<T> result)
    {
        if (result.IsFailure)
        {
            throw new InvalidOperationException(result.Failure?.Message ?? "Application command failed.");
        }
    }

    private static CharacterDto? GetMainCharacter(PlayerDto? player)
        => player is null || !player.MainCharacterId.HasValue
            ? null
            : player.Characters.FirstOrDefault(character => character.Id == player.MainCharacterId);

    private static string FormatCharacter(CharacterDto? character)
        => character is null
            ? "No main character"
            : $"{character.Name} - {character.CharacterClass} {character.Specialization}";

    private sealed record CharacterPreset(
        string Name,
        CharacterClass CharacterClass,
        CharacterSpecialization Specialization,
        CharacterRole Role);
}
