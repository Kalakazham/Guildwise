@page "/roster"
@rendermode InteractiveServer

@using Guildwise.Application.Contracts.RosterOverview
@using Guildwise.Application.RosterOverview.GetRosterOverview
@using Guildwise.Domain
@inject GetRosterOverviewHandler GetRosterOverviewHandler

<PageTitle>Roster Overview</PageTitle>

<main class="roster-overview-page">
    <PageHeader
        Eyebrow="Guildwise roster"
        Title="Roster Overview"
        Subtitle="Scan guild composition, raid team coverage and main-character readiness from the manual roster data already in Guildwise.">
        <Actions>
            <a class="roster-action roster-action--secondary" href="/roster-setup">Setup roster</a>
            <button type="button" class="roster-action" @onclick="LoadRosterAsync">Refresh</button>
        </Actions>
    </PageHeader>

    @if (isLoading)
    {
        <LoadingState Title="Loading roster" Message="Collecting guild, raid team, player and character data." />
    }
    else if (!string.IsNullOrWhiteSpace(loadFailure))
    {
        <ContentPanel Title="Roster unavailable">
            <EmptyState
                Title="Roster data could not be loaded."
                Message="@loadFailure">
                <Actions>
                    <button type="button" class="roster-action" @onclick="LoadRosterAsync">Try again</button>
                </Actions>
            </EmptyState>
        </ContentPanel>
    }
    else if (overview is null || IsRosterEmpty(overview))
    {
        <ContentPanel Title="Roster">
            <EmptyState
                Title="No roster data yet."
                Message="Create a guild, players, characters and a raid team through the setup view to populate this overview.">
                <Actions>
                    <a class="roster-action" href="/roster-setup">Open roster setup</a>
                </Actions>
            </EmptyState>
        </ContentPanel>
    }
    else
    {
        var visibleMembers = GetVisibleMembers();
        var totalMembers = overview.Members.Count;

        <section class="summary-grid" aria-label="Roster summary">
            <SummaryCard Label="Guilds" Value="@overview.Summary.GuildCount.ToString()" Detail="Configured guild contexts" />
            <SummaryCard Label="Players" Value="@overview.Summary.PlayerCount.ToString()" Detail="@($"{overview.Summary.PlayersWithMainCharacterCount} with main characters")" />
            <SummaryCard Label="Characters" Value="@overview.Summary.CharacterCount.ToString()" Detail="Manual character records" />
            <SummaryCard Label="Raid members" Value="@overview.Summary.RaidRosterMemberCount.ToString()" Detail="@($"{overview.Summary.RaidTeamCount} raid teams")" />
        </section>

        <section class="overview-grid">
            <ContentPanel Title="Guild Context" Class="guild-context-panel">
                @if (overview.Guilds.Count == 0)
                {
                    <EmptyState Title="No guild context." Message="Create a guild to anchor the roster overview." />
                }
                else
                {
                    <div class="guild-context-list">
                        @foreach (var guild in overview.Guilds)
                        {
                            <article class="guild-context-card">
                                <div>
                                    <h3>@guild.Name</h3>
                                    <p>@guild.Region - @guild.Realm</p>
                                </div>
                                <dl>
                                    <div>
                                        <dt>Raid teams</dt>
                                        <dd>@guild.RaidTeamCount</dd>
                                    </div>
                                    <div>
                                        <dt>Members</dt>
                                        <dd>@guild.MemberCount</dd>
                                    </div>
                                </dl>
                            </article>
                        }
                    </div>
                }
            </ContentPanel>

            <ContentPanel Title="Roster List" Class="roster-list-panel">
                @if (overview.Members.Count == 0)
                {
                    <EmptyState Title="No players yet." Message="Add players and main characters to start building the roster." />
                }
                else
                {
                    <div class="roster-controls" aria-label="Roster search filter and sort controls">
                        <div class="roster-controls__summary">
                            <span>Showing @visibleMembers.Count of @totalMembers players</span>
                            @if (HasActiveRosterControls)
                            {
                                <button type="button" class="roster-link-action" @onclick="ResetRosterControls">Reset controls</button>
                            }
                        </div>

                        <div class="roster-controls__grid">
                            <label class="roster-control roster-control--wide">
                                Search
                                <input
                                    @bind="searchText"
                                    @bind:event="oninput"
                                    placeholder="Player, character, realm, raid team" />
                            </label>

                            <label class="roster-control">
                                Class
                                <select @bind="selectedClass">
                                    <option value="@AllFilterValue">All classes</option>
                                    @foreach (var characterClass in AvailableClasses)
                                    {
                                        <option value="@characterClass.ToString()">@RosterDisplayText.CharacterClass(characterClass)</option>
                                    }
                                </select>
                            </label>

                            <label class="roster-control">
                                Role
                                <select @bind="selectedRole">
                                    <option value="@AllFilterValue">All roles</option>
                                    @foreach (var role in StableRoles)
                                    {
                                        <option value="@role.ToString()">@RosterDisplayText.CharacterRole(role)</option>
                                    }
                                </select>
                            </label>

                            <label class="roster-control">
                                Guild
                                <select @bind="selectedGuildMembership">
                                    <option value="@AllFilterValue">All players</option>
                                    <option value="@GuildMembersFilterValue">Guild members</option>
                                    <option value="@NotInGuildFilterValue">Not in guild</option>
                                </select>
                            </label>

                            <label class="roster-control">
                                Main
                                <select @bind="selectedMainCharacter">
                                    <option value="@AllFilterValue">All main states</option>
                                    <option value="@HasMainFilterValue">Has main</option>
                                    <option value="@MissingMainFilterValue">Missing main</option>
                                </select>
                            </label>

                            <label class="roster-control">
                                Raid team
                                <select @bind="selectedRaidTeam">
                                    <option value="@AllFilterValue">All raid teams</option>
                                    <option value="@NoRaidTeamFilterValue">No raid team</option>
                                    @foreach (var raidTeam in AvailableRaidTeams)
                                    {
                                        <option value="@raidTeam">@raidTeam</option>
                                    }
                                </select>
                            </label>

                            <label class="roster-control">
                                Sort
                                <select @bind="selectedSort">
                                    <option value="@SortPlayerName">Player name</option>
                                    <option value="@SortMainCharacterName">Main character</option>
                                    <option value="@SortClass">Class</option>
                                    <option value="@SortRole">Role</option>
                                    <option value="@SortGuildRank">Guild rank</option>
                                    <option value="@SortRaidTeamCount">Raid team count</option>
                                    <option value="@SortRaidTeamName">Raid team name</option>
                                </select>
                            </label>
                        </div>
                    </div>

                    @if (visibleMembers.Count == 0)
                    {
                        <EmptyState
                            Title="No roster matches."
                            Message="No players match the current search and filters. Reset the controls or broaden the search to show roster members again.">
                            <Actions>
                                <button type="button" class="roster-action" @onclick="ResetRosterControls">Reset controls</button>
                            </Actions>
                        </EmptyState>
                    }
                    else
                    {
                        <div class="roster-table-wrap">
                            <table class="roster-table">
                                <thead>
                                <tr>
                                    <th>Player</th>
                                    <th>Main character</th>
                                    <th>Class</th>
                                    <th>Role</th>
                                    <th>Main/Alt</th>
                                    <th>Guild rank</th>
                                    <th>Raid teams</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var member in visibleMembers)
                                {
                                    <tr>
                                        <td>
                                            <div class="player-cell">
                                                <span>@member.PlayerDisplayName</span>
                                                @if (!member.IsGuildMember)
                                                {
                                                    <small>Not in guild</small>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            @if (member.HasMainCharacter)
                                            {
                                                <div class="character-cell">
                                                    <span>@member.MainCharacterName</span>
                                                    <small>@member.CharacterRegion - @member.CharacterRealm</small>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="muted">No main character</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="badge-stack">
                                                <CharacterClassBadge Value="member.CharacterClass" />
                                                <SpecializationDisplay Value="member.Specialization" />
                                            </div>
                                        </td>
                                        <td><CharacterRoleBadge Value="member.Role" /></td>
                                        <td>
                                            <MainAltBadge HasMainCharacter="member.HasMainCharacter" />
                                        </td>
                                        <td>
                                            <div class="badge-cluster">
                                                <GuildRankBadge Value="member.GuildRank" />
                                                @foreach (var role in member.AdditionalRoles)
                                                {
                                                    <GuildRoleBadge Value="role" />
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            @if (member.RaidTeamNames.Count == 0)
                                            {
                                                <span class="muted">Unassigned</span>
                                            }
                                            else
                                            {
                                                <div class="team-list">
                                                    @foreach (var team in member.RaidTeamNames)
                                                    {
                                                        <RaidTeamBadge Name="@team" />
                                                    }
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </ContentPanel>
        </section>
    }
</main>